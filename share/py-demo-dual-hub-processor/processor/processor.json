{
  "processor": {
    "name":      "DualProc",
    "uid":       "proc.dualproc.uid00000001",
    "log_level": "info",
    "auth":      { "keyfile": "" }
  },
  "in_hub_dir":  "../hub-a",
  "out_hub_dir": "../hub-b",
  "in_channel":  "lab.demo.counter",
  "out_channel": "lab.demo.processed",
  "in_transport":  "shm",
  "out_transport": "shm",
  "in_shm_enabled":     true,
  "out_shm_enabled":    true,
  "out_shm_slot_count": 256,
  "in_slot_schema": {
    "packing": "aligned",
    "fields": [
      {"name": "count",   "type": "int64"},
      {"name": "ts",      "type": "float64"},
      {"name": "samples", "type": "float32", "count": 1024}
    ]
  },
  "out_slot_schema": {
    "packing": "aligned",
    "fields": [
      {"name": "count",     "type": "int64"},
      {"name": "ts",        "type": "float64"},
      {"name": "processed", "type": "float32", "count": 1024},
      {"name": "slot_mean", "type": "float64"},
      {"name": "slot_std",  "type": "float64"}
    ]
  },
  "out_flexzone_schema": {
    "packing": "aligned",
    "fields": [
      {"name": "total_slots",  "type": "int64"},
      {"name": "running_mean", "type": "float64"}
    ]
  },
  "loop_timing":          "max_rate",
  "checksum":             "enforced",
  "flexzone_checksum":    true,
  "script":               { "type": "python", "path": "." },
  "stop_on_script_error": false
}
