{
  "name": "dual-hub-processor",
  "description": "Dual-hub demo — 2 hubs + dual-presence processor (Wave-B M8 payoff).  Producer on hub-a, processor with Consumer presence on hub-a + Producer presence on hub-b, consumer on hub-b.  Cross-hub data flow.  Shutdown via producer's count target → channel-close cascade (D1/D2 fix) propagates through both hubs.",
  "duration_s": 30,
  "shutdown_signal": "SIGTERM",
  "shutdown_grace_s": 10,

  "setup": {
    "env": { "PYLABHUB_HUB_PASSWORD": "demo-password" },
    "commands": [
      {
        "args":         ["plh_hub", "--config", "hub-a/hub.json", "--keygen"],
        "timeout_s":    20,
        "must_succeed": true
      },
      {
        "args":         ["plh_hub", "--config", "hub-b/hub.json", "--keygen"],
        "timeout_s":    20,
        "must_succeed": true
      }
    ]
  },

  "processes": [
    {
      "name":            "hub-a",
      "binary":          "plh_hub",
      "args":            ["hub-a"],
      "wait_for_marker": "Broker: listening on tcp://127.0.0.1:5570",
      "startup_timeout_s": 10,
      "role_log_glob":   "hub-a/logs/*.log"
    },
    {
      "name":            "hub-b",
      "binary":          "plh_hub",
      "args":            ["hub-b"],
      "wait_for_marker": "Broker: listening on tcp://127.0.0.1:5571",
      "startup_timeout_s": 10,
      "role_log_glob":   "hub-b/logs/*.log"
    },
    {
      "name":            "producer",
      "binary":          "plh_role",
      "args":            ["--role", "producer", "producer"],
      "wait_for_marker": "DualProd started",
      "startup_timeout_s": 10,
      "depends_on":      ["hub-a"],
      "role_log_glob":   "producer/logs/*.log"
    },
    {
      "name":            "processor",
      "binary":          "plh_role",
      "args":            ["--role", "processor", "processor"],
      "wait_for_marker": "DualProc started",
      "startup_timeout_s": 10,
      "depends_on":      ["producer", "hub-b"],
      "role_log_glob":   "processor/logs/*.log"
    },
    {
      "name":            "consumer",
      "binary":          "plh_role",
      "args":            ["--role", "consumer", "consumer"],
      "wait_for_marker": "DualCons started",
      "startup_timeout_s": 10,
      "depends_on":      ["processor"],
      "role_log_glob":   "consumer/logs/*.log"
    }
  ],

  "expected_warnings": [],
  "expected_errors":   [],

  "evaluators": [
    {"type": "all_processes_started"},
    {"type": "log_marker_present", "process": "producer",
     "marker": "DualProd STOPPED total="},
    {"type": "log_marker_present", "process": "processor",
     "marker": "DualProc STOPPED processed="},
    {"type": "log_marker_present", "process": "consumer",
     "marker": "DualCons STOPPED total_received="},
    {"type": "log_marker_present", "process": "producer",
     "marker": "DualProd reached target=1000"},
    {"type": "no_unexpected_errors"},
    {"type": "clean_shutdown"}
  ]
}
