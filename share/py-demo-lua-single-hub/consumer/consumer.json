{
  "consumer": {
    "name":      "LuaCons",
    "uid":       "cons.luacons.uid00000001",
    "log_level": "info",
    "auth":      { "keyfile": "" }
  },
  "in_hub_dir":   "../hub",
  "in_channel":   "lab.demo.lua.processed",
  "in_transport":   "shm",
  "in_shm_enabled": true,
  "in_slot_schema": {
    "packing": "aligned",
    "fields": [
      {"name": "count",    "type": "int64"},
      {"name": "value",    "type": "float64"},
      {"name": "doubled",  "type": "float64"}
    ]
  },
  "in_flexzone_schema": null,
  "loop_timing":          "max_rate",
  "checksum":             "enforced",
  "flexzone_checksum":    false,
  "script":               { "type": "lua", "path": "." },
  "stop_on_script_error": false
}
