{
  "name": "bench-engine-lua",
  "description": "Engine-throughput baseline (Lua / LuaJIT).  Same shape as bench-engine-python: max_rate, scalar 16B slot, band-coordinated shutdown over !bench.shutdown.  40s measurement window + 5s warmup-excluded.",
  "duration_s": 60,
  "shutdown_signal": "SIGTERM",
  "shutdown_grace_s": 10,
  "setup": {
    "env": { "PYLABHUB_HUB_PASSWORD": "demo-password" },
    "commands": [
      {"args": ["plh_hub", "--config", "hub/hub.json", "--keygen"], "timeout_s": 20, "must_succeed": true}
    ]
  },
  "processes": [
    {"name": "hub", "binary": "plh_hub", "args": ["hub"], "wait_for_marker": "Broker: listening on tcp", "startup_timeout_s": 10, "role_log_glob": "hub/logs/*.log"},
    {"name": "producer", "binary": "plh_role", "args": ["--role", "producer", "producer"], "wait_for_marker": "BenchProd-Lua started", "startup_timeout_s": 10, "depends_on": ["hub"], "role_log_glob": "producer/logs/*.log"},
    {"name": "consumer", "binary": "plh_role", "args": ["--role", "consumer", "consumer"], "wait_for_marker": "BenchCons-Lua started", "startup_timeout_s": 10, "depends_on": ["producer"], "role_log_glob": "consumer/logs/*.log"}
  ],
  "expected_warnings": [], "expected_errors": [],
  "evaluators": [
    {"type": "all_processes_started"},
    {"type": "log_marker_present", "process": "producer", "marker": "BENCH-PROD engine=lua"},
    {"type": "log_marker_present", "process": "consumer", "marker": "BENCH-CONS engine=lua"},
    {"type": "log_marker_present", "process": "consumer", "marker": "BenchCons received drain"},
    {"type": "no_unexpected_errors"},
    {"type": "clean_shutdown"}
  ]
}
