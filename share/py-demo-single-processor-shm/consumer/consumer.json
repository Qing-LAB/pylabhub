{
  "consumer": {
    "name":      "DemoConsumer",
    "uid":       "cons.democonsumer.uid00000001",
    "log_level": "info",
    "auth":      { "keyfile": "" }
  },
  "in_hub_dir":   "../hub",
  "in_channel":   "lab.demo.processed",
  "in_transport": "shm",
  "in_shm_enabled": true,
  "in_shm_secret":  2222222222,
  "in_slot_schema": {
    "packing": "aligned",
    "fields": [
      {"name": "count",   "type": "int64"},
      {"name": "ts",      "type": "float64"},
      {"name": "value",   "type": "float32"},
      {"name": "doubled", "type": "float64"}
    ]
  },
  "loop_timing":          "max_rate",
  "checksum":             "enforced",
  "script":               { "type": "python", "path": "." },
  "stop_on_script_error": false
}
