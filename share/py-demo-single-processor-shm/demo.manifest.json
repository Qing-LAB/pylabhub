{
  "name": "single-processor-shm",
  "description": "Single-hub max-rate throughput demo with band-coordinated shutdown.  Producer writes 4096-float32 blocks; processor numpy-reduces per slot + updates flexzone running stats; consumer reads N=20000 slots then broadcasts 'drain' on `!demo.shutdown`.  All three roles api.stop() on the band message (no SIGTERM cascade).",
  "duration_s": 20,
  "shutdown_signal": "SIGTERM",
  "shutdown_grace_s": 10,

  "setup": {
    "env": { "PYLABHUB_HUB_PASSWORD": "demo-password" },
    "commands": [
      {
        "args":         ["plh_hub", "--config", "hub/hub.json", "--keygen"],
        "timeout_s":    20,
        "must_succeed": true
      }
    ]
  },

  "processes": [
    {
      "name":            "hub",
      "binary":          "plh_hub",
      "args":            ["hub"],
      "wait_for_marker": "Broker: listening on tcp",
      "startup_timeout_s": 10,
      "role_log_glob":   "hub/logs/*.log"
    },
    {
      "name":            "producer",
      "binary":          "plh_role",
      "args":            ["--role", "producer", "producer"],
      "wait_for_marker": "DemoProducer started",
      "startup_timeout_s": 10,
      "depends_on":      ["hub"],
      "role_log_glob":   "producer/logs/*.log"
    },
    {
      "name":            "processor",
      "binary":          "plh_role",
      "args":            ["--role", "processor", "processor"],
      "wait_for_marker": "DemoProcessor started",
      "startup_timeout_s": 10,
      "depends_on":      ["producer"],
      "role_log_glob":   "processor/logs/*.log"
    },
    {
      "name":            "consumer",
      "binary":          "plh_role",
      "args":            ["--role", "consumer", "consumer"],
      "wait_for_marker": "DemoConsumer started",
      "startup_timeout_s": 10,
      "depends_on":      ["processor"],
      "role_log_glob":   "consumer/logs/*.log"
    }
  ],

  "expected_warnings": [],
  "expected_errors": [],

  "evaluators": [
    {"type": "all_processes_started"},
    {"type": "log_marker_present", "process": "producer",
     "marker": "DemoProducer STOPPED total="},
    {"type": "log_marker_present", "process": "processor",
     "marker": "DemoProcessor STOPPED processed="},
    {"type": "log_marker_present", "process": "consumer",
     "marker": "DemoConsumer STOPPED total_received="},
    {"type": "log_marker_min_count", "process": "consumer",
     "marker": "flexzone running:", "min": 1},
    {"type": "log_marker_present", "process": "consumer",
     "marker": "broadcasting 'drain' on '!demo.shutdown'"},
    {"type": "log_marker_present", "process": "producer",
     "marker": "DemoProducer received 'drain' on '!demo.shutdown'"},
    {"type": "log_marker_present", "process": "processor",
     "marker": "DemoProcessor received 'drain' on '!demo.shutdown'"},
    {"type": "no_unexpected_errors"},
    {"type": "clean_shutdown"}
  ]
}
