{
  "_comment": [
    "Dual-hub demo consumer — reads processed 1k-sample slots from Hub B and reports throughput.",
    "Run with: pylabhub-consumer <path-to-this-dir>",
    "Script at: ./script/python/__init__.py  (on_init / on_consume / on_stop)"
  ],
  "hub_dir": "../hub-b",
  "consumer": {
    "uid":       "CONS-BRIDGE-00000001",
    "name":      "BridgeConsumer",
    "log_level": "info",
    "auth": { "keyfile": "" }
  },
  "channel":    "lab.bridge.processed",
  "broker":     "tcp://127.0.0.1:5571",
  "slot_acquire_timeout_ms": -1,

  "shm": {
    "enabled": true,
    "secret":  4444444444
  },

  "slot_schema": {
    "packing": "aligned",
    "fields": [
      {"name": "count",   "type": "int64"},
      {"name": "ts",      "type": "float64"},
      {"name": "samples", "type": "float32", "count": 1024},
      {"name": "scale",   "type": "float32"}
    ]
  },
  "flexzone_schema": null,

  "script": { "type": "python", "path": "." },

  "max_slots": 1000000,

  "validation": {
    "stop_on_script_error": false
  }
}
