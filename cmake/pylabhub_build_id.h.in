#pragma once
/**
 * @file pylabhub_build_id.h
 * @brief Build identifier for ABI freshness checks (generated by CMake).
 *
 * Do not edit directly.  Regenerated from cmake/pylabhub_build_id.h.in on
 * every CMake configure.  The value is `<git-short-sha>-<build-type>`
 * (e.g. `1a2b3c4d5e6f-Debug`), or `<unknown>-<build-type>` when git metadata
 * is unavailable.  Used by `pylabhub::version::abi_expected_here()` in
 * strict mode to catch stale-binary-vs-fresh-library mismatches that the
 * coarse ComponentVersions axes would miss.
 *
 * See `plh_version_registry.hpp` for the consuming API.
 */

#define PYLABHUB_HAVE_BUILD_ID 1
#define PYLABHUB_BUILD_ID      "@PYLABHUB_BUILD_ID_VALUE@"
