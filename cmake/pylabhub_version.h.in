/**
 * @file pylabhub_version.h
 * @brief Version information for the pylabhub package (generated by CMake).
 *
 * Do not edit directly. This file is generated from cmake/pylabhub_version.h.in
 * at configure time. Version values come from cmake/Versions.cmake.
 */
#pragma once

// Library SOVERSION (numeric: major.minor.rolling)
#define PYLABHUB_VERSION_MAJOR   @PYLABHUB_VERSION_MAJOR@
#define PYLABHUB_VERSION_MINOR   @PYLABHUB_VERSION_MINOR@
#define PYLABHUB_VERSION_ROLLING @PYLABHUB_VERSION_ROLLING@
#define PYLABHUB_VERSION_STRING  "@PYLABHUB_VERSION_STRING@"

// Release version (PEP 440, e.g., "0.1.0a0")
#define PYLABHUB_RELEASE_VERSION "@PYLABHUB_RELEASE_VERSION@"

// Bundled Python runtime version (e.g., "3.14.3+20260211")
#define PYLABHUB_PYTHON_RUNTIME_VERSION "@PYLABHUB_PYTHON_RUNTIME_VERSION@"
