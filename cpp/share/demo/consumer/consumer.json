{
  "_comment": [
    "Demo consumer — reads the processed channel 'lab.demo.processed' and logs slots.",
    "Run with: pylabhub-consumer <path-to-this-dir>",
    "Script at: ./script/python/__init__.py  (on_init / on_consume / on_stop)"
  ],
  "hub_dir": "../hub",
  "consumer": {
    "uid":       "CONS-LOGGER-00000004",
    "name":      "DemoConsumer",
    "log_level": "info",
    "auth": { "keyfile": "" }
  },
  "channel":    "lab.demo.processed",
  "broker":     "tcp://127.0.0.1:5570",
  "timeout_ms": 5000,

  "shm": {
    "enabled": true,
    "secret":  2222222222
  },

  "slot_schema": "lab.demo.processed@1",
  "flexzone_schema": "lab.demo.processed@1",

  "script": { "type": "python", "path": "." },

  "validation": {
    "stop_on_script_error": false
  }
}
