{
  "_comment": [
    "Demo processor — reads 1k-sample blocks from 'lab.demo.counter', doubles them, writes 'lab.demo.processed'.",
    "Run with: pylabhub-processor <path-to-this-dir>",
    "Script at: ./script/python/__init__.py  (on_init / on_process / on_stop)"
  ],
  "processor": {
    "uid":       "PROC-DOUBLER-00000003",
    "name":      "DemoDoubler",
    "log_level": "info"
  },
  "in_channel":  "lab.demo.counter",
  "out_channel": "lab.demo.processed",
  "hub_dir":     "../hub",
  "broker":      "tcp://127.0.0.1:5570",
  "timeout_ms":          500,
  "target_period_ms":    0,
  "loop_timing":         "max_rate",
  "overflow_policy":   "block",

  "shm": {
    "in":  {"enabled": true, "secret": 1111111111},
    "out": {"enabled": true, "secret": 2222222222, "slot_count": 8}
  },

  "in_slot_schema": "lab.demo.counter@1",
  "out_slot_schema": "lab.demo.processed@1",
  "flexzone_schema": null,

  "script": {"type": "python", "path": "."},

  "validation": {
    "update_checksum":      true,
    "stop_on_script_error": false
  }
}
