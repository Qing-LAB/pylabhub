{
  "_comment": "Dual-hub demo producer — publishes lab.bridge.raw on Hub A (5570)",
  "hub_dir": "../hub-a",
  "producer": {
    "uid":       "PROD-BRIDGE-00000001",
    "name":      "BridgeProducer",
    "log_level": "info",
    "auth": { "keyfile": "" }
  },
  "channel":     "lab.bridge.raw",
  "broker":      "tcp://127.0.0.1:5570",
  "target_period_ms": 10,
  "loop_timing":      "fixed_rate",

  "shm": {
    "enabled":    true,
    "secret":     3333333333,
    "slot_count": 8
  },

  "slot_schema": {
    "packing": "aligned",
    "fields": [
      {"name": "count", "type": "int64"},
      {"name": "ts",    "type": "float64"},
      {"name": "value", "type": "float32"}
    ]
  },
  "flexzone_schema": null,

  "script": { "type": "python", "path": "." },

  "validation": {
    "update_checksum":      true,
    "stop_on_script_error": false
  }
}
