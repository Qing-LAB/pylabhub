{
  "_comment": "Dual-hub demo consumer — reads lab.bridge.processed from Hub B (5571)",
  "hub_dir": "../hub-b",
  "consumer": {
    "uid":       "CONS-BRIDGE-00000001",
    "name":      "BridgeConsumer",
    "log_level": "info",
    "auth": { "keyfile": "" }
  },
  "channel":    "lab.bridge.processed",
  "broker":     "tcp://127.0.0.1:5571",
  "timeout_ms": 500,

  "shm": {
    "enabled": true,
    "secret":  4444444444
  },

  "slot_schema": {
    "packing": "aligned",
    "fields": [
      {"name": "count",   "type": "int64"},
      {"name": "ts",      "type": "float64"},
      {"name": "value",   "type": "float32"},
      {"name": "doubled", "type": "float32"}
    ]
  },
  "flexzone_schema": null,

  "script": { "type": "python", "path": "." },

  "validation": {
    "stop_on_script_error": false
  }
}
